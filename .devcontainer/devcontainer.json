{
  "name": "agent-ebpf-filiter dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "GO_VERSION": "1.26.2",
      "USER_UID": "1001",
      "USER_GID": "1001"
    }
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/agent-ebpf-filiter",
  "privileged": true,
  "capAdd": [
    "SYS_ADMIN",
    "SYS_RESOURCE",
    "SYS_PTRACE",
    "NET_ADMIN",
    "BPF",
    "PERFMON"
  ],
  "securityOpt": [
    "apparmor=unconfined",
    "seccomp=unconfined"
  ],
  "runArgs": [
    "--init",
    "--pid=host",
    "--network=host"
  ],
  "mounts": [
    "source=/sys/kernel/debug,target=/sys/kernel/debug,type=bind,consistency=cached",
    "source=/sys/fs/bpf,target=/sys/fs/bpf,type=bind,consistency=cached",
    "source=/lib/modules,target=/lib/modules,type=bind,readonly,consistency=cached"
  ],
  "containerEnv": {
    "GIN_MODE": "debug",
    "DISABLE_AUTH": "true",
    "BUN_INSTALL": "/usr/local/bun"
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "Vue.volar",
        "ms-vscode.cpptools",
        "vadimcn.vscode-lldb",
        "zxh404.vscode-proto3"
      ],
      "settings": {
        "go.toolsManagement.autoUpdate": true,
        "terminal.integrated.defaultProfile.linux": "fish"
      }
    }
  },
  "forwardPorts": [5173, 8080, 8081, 8082, 8083, 8084, 8085, 8086, 8087, 8088, 8089],
  "portsAttributes": {
    "5173": { "label": "Vite frontend" },
    "8080": { "label": "Backend API" }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
